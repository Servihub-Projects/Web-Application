// ServiHub — PostgreSQL schema (reference only, not connected)
// Migration path: npx prisma init → update DATABASE_URL → npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  PROVIDER
}

enum BookingStatus {
  PENDING
  ESCROW_PAID
  IN_PROGRESS
  COMPLETED
  RELEASED
  DECLINED
}

enum PriceType {
  FIXED
  HOURLY
}

enum EscrowTransactionType {
  DEPOSIT
  UPFRONT_RELEASE
  COMPLETION_RELEASE
  PLATFORM_FEE
  REFUND
}

enum EscrowTransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole
  avatar       String?
  bio          String?
  rating       Float?
  reviewCount  Int      @default(0)
  hourlyRate   Float?
  skills       String[]
  location     String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  servicesProvided Service[]
  bookingsAsClient Booking[] @relation("ClientBookings")
  bookingsAsProvider Booking[] @relation("ProviderBookings")
  messagesSent    Message[] @relation("SentMessages")
  messagesReceived Message[] @relation("ReceivedMessages")

  @@index([email])
  @@index([role])
}

model Service {
  id           String          @id @default(cuid())
  providerId   String
  title        String
  description  String
  category     String
  price        Float
  priceType    PriceType
  rating       Float           @default(0)
  reviewCount  Int             @default(0)
  deliveryTime Int
  tags         String[]
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  provider     User            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  bookings     Booking[]

  @@index([providerId])
  @@index([category])
  @@index([isActive])
}

model Booking {
  id             String        @id @default(cuid())
  serviceId      String
  clientId       String
  providerId     String
  status         BookingStatus @default(PENDING)
  totalAmount    Float
  platformFee    Float
  escrowAmount   Float         @default(0)
  upfrontPaid    Boolean       @default(false)
  completionPaid Boolean       @default(false)
  description    String
  startDate      DateTime
  completionDate DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  service        Service       @relation(fields: [serviceId], references: [id])
  client         User          @relation("ClientBookings", fields: [clientId], references: [id])
  provider       User          @relation("ProviderBookings", fields: [providerId], references: [id])
  escrowTransactions EscrowTransaction[]
  messages       Message[]

  @@index([clientId])
  @@index([providerId])
  @@index([status])
}

model EscrowTransaction {
  id        String                  @id @default(cuid())
  bookingId String
  amount    Float
  type      EscrowTransactionType
  status    EscrowTransactionStatus @default(PENDING)
  createdAt DateTime                @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model Message {
  id         String   @id @default(cuid())
  bookingId  String
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([bookingId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
}
