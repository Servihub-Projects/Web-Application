generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  PROVIDER
  ADMIN
}

enum CurrencyCode {
  NGN
  USD
  GBP
  EUR
  GHS
}

enum BookingStatus {
  PROPOSAL_SENT
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  DECLINED
  CANCELLED
  DISPUTED
}

enum BookingInitiator {
  CLIENT
  PROVIDER
}

enum PriceType {
  FIXED
  HOURLY
}

enum JobRequestStatus {
  OPEN
  ASSIGNED
  CLOSED
}

enum JobUrgency {
  FLEXIBLE
  WITHIN_WEEK
  URGENT
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_DECLINED
  BOOKING_COMPLETED
  NEW_MESSAGE
  JOB_REVIEW
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum PromotionPlacementType {
  PROVIDER_CARD
  SERVICE_LISTING
  FEATURED_SLOT
  BANNER_CARD
}

enum PromotionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  ENDED
}

enum PromotionEventType {
  IMPRESSION
  CLICK
  CONVERSION
}

model User {
  id                       String       @id @default(cuid())
  email                    String       @unique
  passwordHash             String
  name                     String
  role                     UserRole
  avatar                   String?
  bio                      String?
  yearsOfExperience        Int?
  rating                   Float?
  reviewCount              Int          @default(0)
  hourlyRate               Float?
  skills                   String[]
  location                 String?
  preferredCurrency        CurrencyCode @default(NGN)
  isVerified               Boolean      @default(false)
  providerDetailsCompleted Boolean      @default(false)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  servicesProvided          Service[]
  bookingsAsClient          Booking[]            @relation("ClientBookings")
  bookingsAsProvider        Booking[]            @relation("ProviderBookings")
  jobRequests               JobRequest[]
  messagesSent              Message[]            @relation("SentMessages")
  messagesReceived          Message[]            @relation("ReceivedMessages")
  passwordResetTokens       PasswordResetToken[]
  notifications             Notification[]
  auditLogs                 AuditLog[]           @relation("AuditActor")
  promotionCampaigns        PromotionCampaign[]  @relation("ProviderPromotionCampaigns")
  promotionEventsAsActor    PromotionEvent[]     @relation("PromotionEventActor")
  promotionEventsAsProvider PromotionEvent[]     @relation("PromotionEventProvider")

  @@index([email])
  @@index([role])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, used])
  @@index([expiresAt])
}

model Service {
  id           String    @id @default(cuid())
  providerId   String
  title        String
  description  String
  category     String
  price        Decimal   @db.Decimal(14, 2)
  priceType    PriceType
  rating       Float     @default(0)
  reviewCount  Int       @default(0)
  deliveryTime Int
  tags         String[]
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  provider           User                @relation(fields: [providerId], references: [id], onDelete: Cascade)
  bookings           Booking[]
  promotionCampaigns PromotionCampaign[]
  promotionEvents    PromotionEvent[]

  @@index([providerId])
  @@index([category])
  @@index([isActive])
}

model Booking {
  id              String           @id @default(cuid())
  serviceId       String
  clientId        String
  providerId      String
  status          BookingStatus    @default(PENDING)
  initiatedBy     BookingInitiator @default(CLIENT)
  totalAmount     Decimal          @db.Decimal(14, 2)
  platformFee     Decimal          @db.Decimal(14, 2)
  currency        CurrencyCode     @default(NGN)
  description     String
  proposalMessage String?
  jobRequestId    String?
  startDate       DateTime
  completionDate  DateTime?
  cancelledAt     DateTime?
  cancelledReason String?
  disputedAt      DateTime?
  disputeReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  service       Service        @relation(fields: [serviceId], references: [id])
  client        User           @relation("ClientBookings", fields: [clientId], references: [id])
  provider      User           @relation("ProviderBookings", fields: [providerId], references: [id])
  jobRequest    JobRequest?    @relation(fields: [jobRequestId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  messages      Message[]

  @@index([clientId])
  @@index([providerId])
  @@index([status])
  @@index([jobRequestId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  actionUrl String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([isRead])
}

model JobRequest {
  id          String           @id @default(cuid())
  clientId    String
  title       String
  description String
  category    String
  budgetMin   Decimal          @db.Decimal(14, 2)
  budgetMax   Decimal          @db.Decimal(14, 2)
  location    String
  urgency     JobUrgency
  status      JobRequestStatus @default(OPEN)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  client        User           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  bookings      Booking[]

  @@index([clientId])
  @@index([status])
  @@index([category])
}

model Conversation {
  id            String   @id @default(cuid())
  participants  String[]
  bookingId     String?
  jobRequestId  String?
  lastMessage   String
  lastMessageAt DateTime
  unreadCount   Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  booking    Booking?    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  jobRequest JobRequest? @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@index([bookingId])
  @@index([jobRequestId])
  @@index([lastMessageAt])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  bookingId      String?
  senderId       String
  receiverId     String
  content        String
  type           MessageType @default(TEXT)
  isRead         Boolean     @default(false)
  attachment     Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
  receiver     User         @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([conversationId])
  @@index([bookingId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
}

model PromotionCampaign {
  id            String                 @id @default(cuid())
  providerId    String?
  serviceId     String?
  placementType PromotionPlacementType
  status        PromotionStatus        @default(DRAFT)
  title         String
  priority      Int                    @default(0)
  budgetAmount  Decimal?               @db.Decimal(14, 2)
  currency      CurrencyCode           @default(NGN)
  startsAt      DateTime?
  endsAt        DateTime?
  metadata      Json?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  provider User?            @relation("ProviderPromotionCampaigns", fields: [providerId], references: [id], onDelete: Cascade)
  service  Service?         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  events   PromotionEvent[]

  @@index([status, placementType])
  @@index([providerId])
  @@index([serviceId])
  @@index([startsAt, endsAt])
}

model PromotionEvent {
  id           String             @id @default(cuid())
  campaignId   String?
  actorUserId  String?
  providerId   String?
  serviceId    String?
  eventType    PromotionEventType
  placementKey String
  metadata     Json?
  occurredAt   DateTime           @default(now())

  campaign PromotionCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  actor    User?              @relation("PromotionEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  provider User?              @relation("PromotionEventProvider", fields: [providerId], references: [id], onDelete: Cascade)
  service  Service?           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([campaignId, eventType])
  @@index([providerId])
  @@index([serviceId])
  @@index([occurredAt])
}

model Waitlist {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  company   String?
  useCase   String
  createdAt DateTime @default(now())
}
